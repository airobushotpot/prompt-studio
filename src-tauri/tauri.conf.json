{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prompt Studio",
  "version": "0.1.0",
  "identifier": "com.promptstudio.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prompt Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["macos", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "entitlements": null,
      "providerShortName": null,
      "signingIdentity": null
    },
    "shortDescription": "AI提示词管理工具",
    "longDescription": "可视化管理和编辑AI提示词的工具，支持变量高亮、模板、历史版本等功能"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:promptstudio.db"]
    }
  }
}
